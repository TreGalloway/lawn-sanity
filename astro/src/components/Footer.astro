---
import { fetchServiceAreas, fetchServices } from '../lib/sanity';
import type { SiteSettings } from '../types';

interface Props {
  siteData: SiteSettings;
}

const { siteData } = Astro.props;

const serviceAreas = await fetchServiceAreas();
const services = await fetchServices();

const serviceAreasList = serviceAreas.length > 0 
  ? serviceAreas.map(a => a.areaName)
  : ['Flint', 'Flint Township', 'Flushing', 'Mt. Morris', 'Grand Blanc'];

const footerServices = services.length > 0 
  ? services.slice(0, 4) 
  : [
      { name: 'Lawn Mowing', slug: { current: 'lawn-mowing' } },
      { name: 'Snow Removal', slug: { current: 'snow-removal' } },
      { name: 'Fertilizing', slug: { current: 'fertilizing' } },
      { name: 'Leaf Removal', slug: { current: 'leaf-removal' } },
    ];

const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="px-3 py-1.5 bg-primary-500 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg">
              {siteData.companyName}
            </span>
          </div>
        </div>
        <p class="text-gray-400 mb-6 max-w-md">
          {siteData.footerTagline}
        </p>
        <div class="flex flex-col gap-2">
          <a
            href={`tel:${siteData.phoneNumber?.replace(/\D/g, '')}`}
            class="flex items-center gap-2 text-gray-300 hover:text-white transition-colors"
          >
            <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {siteData.phoneNumber}
          </a>
          {siteData.email && (
            <a
              href={`mailto:${siteData.email}`}
              class="flex items-center gap-2 text-gray-300 hover:text-white transition-colors"
            >
              <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {siteData.email}
            </a>
          )}
          {siteData.facebookUrl && (
            <a
              href={siteData.facebookUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-gray-300 hover:text-white transition-colors"
            >
              <svg class="w-5 h-5 text-primary-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Follow us on Facebook
            </a>
          )}
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-4 text-accent-400">Services</h3>
        <ul class="space-y-2">
          <li><a href="/services" class="text-gray-400 hover:text-white transition-colors">All Services</a></li>
          {footerServices.map((service) => (
            <li><a href={`/services/${service.slug.current}`} class="text-gray-400 hover:text-white transition-colors">{service.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-4 text-accent-400">Service Areas</h3>
        <ul class="space-y-2">
          {serviceAreasList.map((area) => (
            <li class="text-gray-400">{area}</li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-400 text-sm">
          &copy; {currentYear} {siteData.companyName}. All rights reserved.
        </p>
        <div class="flex gap-4">
          <a href="/privacy" class="text-gray-400 hover:text-white text-sm transition-colors">Privacy Policy</a>
          <a href="/terms" class="text-gray-400 hover:text-white text-sm transition-colors">Terms of Service</a>
        </div>
      </div>
    </div>
  </div>
</footer>
