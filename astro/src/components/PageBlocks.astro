---
import type { PageBlock } from '../types';
import RichText from './RichText';
import ServiceGrid from './ServiceGrid.astro';
import ServiceAreas from './ServiceAreas.astro';
import { fetchServices, fetchServiceAreas, fetchGalleryItems, fetchSiteSettings } from '../lib/sanity';
import { urlFor } from '../lib/sanity';
import type { SiteSettings } from '../types';

interface Props {
  blocks: PageBlock[];
  siteData?: SiteSettings;
}

const { blocks, siteData } = Astro.props;
---

{blocks.map((block) => {
  switch (block._type) {
    case 'hero':
      return (
        <section class="relative bg-gray-900 text-white py-24 lg:py-32">
          {block.backgroundImage && (
            <div class="absolute inset-0">
              <img
                src={urlFor(block.backgroundImage).width(1920).height(800).url()}
                alt=""
                class="w-full h-full object-cover opacity-40"
              />
            </div>
          )}
          <div class="absolute inset-0 bg-gradient-to-br from-gray-900/80 via-gray-800/80 to-primary-900/80"></div>
          <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            {block.title && (
              <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold mb-6">
                {block.title}
              </h1>
            )}
            {block.subtitle && (
              <p class="text-xl lg:text-2xl text-gray-300 mb-8 max-w-2xl mx-auto">
                {block.subtitle}
              </p>
            )}
            {block.ctaText && (
              <a
                href={block.ctaLink || siteData?.yardbookUrl || '#'}
                target={block.ctaLink ? '_blank' : undefined}
                rel={block.ctaLink ? 'noopener noreferrer' : undefined}
                class="inline-flex items-center justify-center gap-2 bg-accent-500 hover:bg-accent-600 text-gray-900 px-8 py-4 rounded-lg font-bold text-lg transition-colors"
              >
                {block.ctaText}
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            )}
          </div>
        </section>
      );

    case 'serviceGrid':
      return (
        <ServiceGrid services={block.services} />
      );

    case 'ctaBanner':
      return (
        <section class="py-16 lg:py-24 bg-primary-500">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            {block.title && (
              <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
                {block.title}
              </h2>
            )}
            {block.description && (
              <p class="text-lg text-primary-100 mb-8 max-w-2xl mx-auto">
                {block.description}
              </p>
            )}
            {block.buttonText && (
              <a
                href={block.buttonLink || siteData?.yardbookUrl || '#'}
                target={block.buttonLink ? '_blank' : undefined}
                rel={block.buttonLink ? 'noopener noreferrer' : undefined}
                class="inline-flex items-center justify-center gap-2 bg-accent-500 hover:bg-accent-600 text-gray-900 px-8 py-4 rounded-lg font-bold text-lg transition-colors"
              >
                {block.buttonText}
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            )}
          </div>
        </section>
      );

    case 'gallery':
      return (
        <section class="py-16 lg:py-24 bg-gray-50">
          <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
              <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Our Work</h2>
            </div>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {(block.items || []).map((item: any) => (
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
                  <div class="aspect-video bg-gray-200 flex items-center justify-center">
                    {item.image ? (
                      <img
                        src={urlFor(item.image).width(600).height(400).url()}
                        alt={item.title || 'Gallery image'}
                        class="w-full h-full object-cover"
                      />
                    ) : (
                      <svg class="w-16 h-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    )}
                  </div>
                  {(item.title || item.description) && (
                    <div class="p-6">
                      {item.title && <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>}
                      {item.description && <p class="text-gray-600 text-sm">{item.description}</p>}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        </section>
      );

    case 'serviceAreas':
      return (
        <ServiceAreas areas={block.areas} />
      );

    case 'richText':
      return (
        <section class="py-16 lg:py-24 bg-gray-50">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="bg-white rounded-2xl p-8 lg:p-12 shadow-sm prose prose-lg max-w-none">
              {block.content && <RichText value={block.content} />}
            </div>
          </div>
        </section>
      );

    case 'contactForm':
      return (
        <section class="py-16 lg:py-24 bg-gray-50">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            {block.title && (
              <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4 text-center">{block.title}</h2>
            )}
            {block.description && (
              <p class="text-lg text-gray-600 mb-8 text-center max-w-2xl mx-auto">{block.description}</p>
            )}
            <div class="bg-white rounded-2xl p-8 shadow-sm text-center">
              <a
                href={siteData?.yardbookUrl || '#'}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 bg-primary-500 hover:bg-primary-600 text-white px-8 py-4 rounded-lg font-bold text-lg transition-colors"
              >
                {siteData?.contactQuoteButtonText || 'Request a Quote'}
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
              {siteData?.contactQuoteHelperText && (
                <p class="text-center text-gray-500 text-sm mt-4">{siteData.contactQuoteHelperText}</p>
              )}
            </div>
          </div>
        </section>
      );

    default:
      return null;
  }
})}
