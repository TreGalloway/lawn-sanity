---
import type { ServiceArea } from '../types';

interface Props {
  areas?: ServiceArea[];
}

const DEFAULT_AREAS = [
  { _id: '1', areaName: 'Flint' },
  { _id: '2', areaName: 'Flint Township' },
  { _id: '3', areaName: 'Flushing' },
  { _id: '4', areaName: 'Mt. Morris' },
  { _id: '5', areaName: 'Grand Blanc' },
];

const { areas } = Astro.props;
const serviceAreas = areas && areas.length > 0 ? areas : DEFAULT_AREAS;
---

<section class="py-16 lg:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Service Areas
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        We're proud to serve the greater Flint, MI area with professional lawn care services.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
      {serviceAreas.map((area) => (
        <div class="bg-gray-50 rounded-xl p-6 text-center hover:bg-primary-50 transition-colors">
          <svg class="w-8 h-8 text-primary-500 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="font-semibold text-gray-900">{area.areaName}</span>
        </div>
      ))}
    </div>
  </div>
</section>
