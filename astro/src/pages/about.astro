---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import RichText from '../components/RichText';
import PageBlocks from '../components/PageBlocks.astro';
import { fetchSiteSettings, fetchPageBySlug } from '../lib/sanity';

const siteData = await fetchSiteSettings();
const page = await fetchPageBySlug('about');

const pageBlocks = page?.blocks;
---

<Layout title="About" description="Learn about MI Premier Lawn Care - Your trusted local lawn care experts in Flint, MI and surrounding areas.">
  {pageBlocks && pageBlocks.length > 0 ? (
    <PageBlocks blocks={pageBlocks} siteData={siteData} />
  ) : (
    <section class="py-16 lg:py-24 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-8 text-center">
          About Us
        </h1>
        
        <div class="bg-white rounded-2xl p-8 lg:p-12 shadow-sm mb-12">
          <div class="prose prose-lg max-w-none">
            <p class="text-xl text-gray-600 mb-6">
              <strong>MI Premier Lawn Care, L.L.C</strong> is a locally-owned and operated lawn care business 
              serving Flint, MI and the surrounding areas. We're committed to providing professional, 
              reliable lawn care services that you can trust.
            </p>

            <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Our Mission</h2>
            <p class="text-gray-600 mb-6">
              Our mission is simple: to provide top-quality lawn care services at affordable prices. 
              We believe every homeowner deserves a beautiful, healthy lawn without breaking the bank.
            </p>

            <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Why Choose Us?</h2>
            <ul class="space-y-4 mb-6">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-primary-500 flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <strong class="text-gray-900">Local & Trusted</strong>
                  <p class="text-gray-600">We're proud to serve our community with honest, reliable service.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-primary-500 flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <strong class="text-gray-900">Free Estimates</strong>
                  <p class="text-gray-600">We provide free quotes on all services with no obligation.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-primary-500 flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <strong class="text-gray-900">Quality Service</strong>
                  <p class="text-gray-600">We take pride in our work and treat every lawn as if it were our own.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-primary-500 flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <strong class="text-gray-900">Affordable Pricing</strong>
                  <p class="text-gray-600">Professional lawn care shouldn't cost a fortune.</p>
                </div>
              </li>
            </ul>

            <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Contact Us</h2>
            <p class="text-gray-600 mb-4">
              Ready to transform your lawn? Contact us today for a free estimate.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href={`tel:${siteData.phoneNumber?.replace(/\D/g, '')}`}
                class="inline-flex items-center gap-2 text-primary-500 hover:text-primary-600 font-semibold"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                {siteData.phoneNumber}
              </a>
              {siteData.email && (
                <a
                  href={`mailto:${siteData.email}`}
                  class="inline-flex items-center gap-2 text-primary-500 hover:text-primary-600 font-semibold"
                >
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  {siteData.email}
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}
  <CTABanner siteData={siteData} />
</Layout>
