---
import Layout from '../layouts/Layout.astro';
import { fetchSiteSettings } from '../lib/sanity';

const siteData = await fetchSiteSettings();
---

<Layout title="Contact" description="Contact MI Premier Lawn Care for a free quote on lawn care services in Flint, MI and surrounding areas.">
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
          Contact Us
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          {siteData.contactPageSubtitle || 'Ready to get started? Contact us today for a free quote on lawn care services.'}
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">{siteData.contactGetInTouchTitle || 'Get in Touch'}</h2>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Phone</h3>
                <a href={`tel:${siteData.phoneNumber?.replace(/\D/g, '')}`} class="text-primary-500 hover:text-primary-600">
                  {siteData.phoneNumber}
                </a>
              </div>
            </div>

            {siteData.email && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 mb-1">Email</h3>
                  <a href={`mailto:${siteData.email}`} class="text-primary-500 hover:text-primary-600">
                    {siteData.email}
                  </a>
                </div>
              </div>
            )}

            {siteData.address && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 mb-1">Service Area</h3>
                  <p class="text-gray-600">{siteData.address}</p>
                </div>
              </div>
            )}

            {siteData.hoursOfOperation && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 mb-1">Hours</h3>
                  <p class="text-gray-600">{siteData.hoursOfOperation}</p>
                </div>
              </div>
            )}
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">{siteData.contactGetQuoteTitle || 'Get a Free Quote'}</h2>
          <p class="text-gray-600 mb-6">
            Ready to get started? Contact us for a free estimate on our lawn care services.
          </p>
          <a
            href={siteData.yardbookUrl || '#'}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-primary-500 hover:bg-primary-600 text-white px-8 py-4 rounded-lg font-bold text-lg transition-colors w-full"
          >
            {siteData.contactQuoteButtonText || 'Request a Quote'}
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <p class="text-center text-gray-500 text-sm mt-4">
            {siteData.contactQuoteHelperText || 'Click above to book through our online system'}
          </p>

          {siteData.facebookUrl && (
            <div class="mt-8 pt-8 border-t border-gray-200">
              <h3 class="font-semibold text-gray-900 mb-4">Follow Us</h3>
              <a
                href={siteData.facebookUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-primary-500 hover:text-primary-600"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Follow us on Facebook for updates
              </a>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</Layout>
