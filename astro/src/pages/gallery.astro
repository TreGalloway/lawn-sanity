---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import { fetchGalleryItems, fetchSiteSettings } from '../lib/sanity';
import { urlFor } from '../lib/sanity';

const siteData = await fetchSiteSettings();
const galleryItems = await fetchGalleryItems();

const defaultImages = [
  { _id: '1', title: 'Lawn Care', description: 'Professional lawn maintenance' },
  { _id: '2', title: 'Spring Cleanup', description: 'Complete spring yard cleanup' },
  { _id: '3', title: 'Mulching', description: 'Fresh mulch installation' },
  { _id: '4', title: 'Hedge Trimming', description: 'Neat and professional hedges' },
  { _id: '5', title: 'Leaf Removal', description: 'Fall leaf cleanup' },
  { _id: '6', title: 'Commercial Properties', description: 'Professional property maintenance' },
];

const displayItems = galleryItems.length > 0 ? galleryItems : defaultImages;
---

<Layout title="Gallery" description="See our work - photos of lawn care, landscaping, and property maintenance services in Flint, MI.">
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
          Our Work
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          See examples of our lawn care and landscaping work in the Flint, MI area.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {displayItems.map((item) => (
          <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
            <div class="aspect-video bg-gray-200 flex items-center justify-center">
              {item.image ? (
                <img 
                  src={urlFor(item.image).width(600).height(400).url()} 
                  alt={item.title || 'Gallery image'}
                  class="w-full h-full object-cover"
                />
              ) : (
                <svg class="w-16 h-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              )}
            </div>
            <div class="p-6">
              <h3 class="text-lg font-bold text-gray-900 mb-2">
                {item.title || 'Project'}
              </h3>
              {item.description && (
                <p class="text-gray-600 text-sm">
                  {item.description}
                </p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <CTABanner siteData={siteData} />
</Layout>
