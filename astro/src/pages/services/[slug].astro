---
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/CTABanner.astro';
import { fetchServiceBySlug, fetchSiteSettings } from '../../lib/sanity';

const { slug } = Astro.params;

const siteData = await fetchSiteSettings();
const service = await fetchServiceBySlug(slug as string);

const FALLBACK_INFO: Record<string, { name: string; description: string; features: string[] }> = {
  'mowing': {
    name: 'Mowing',
    description: 'Professional mowing services with attention to detail. We provide weekly and biweekly mowing including string trimming, edging, and blowing for a polished finish.',
    features: ['Weekly or biweekly schedules', 'String trimming included', 'Edge trimming', 'Debris blowing', 'Consistent cutting height'],
  },
  'lawn-mowing': {
    name: 'Lawn Mowing',
    description: 'Professional mowing services with attention to detail. We provide weekly and biweekly mowing including string trimming, edging, and blowing for a polished finish.',
    features: ['Weekly or biweekly schedules', 'String trimming included', 'Edge trimming', 'Debris blowing', 'Consistent cutting height'],
  },
  'hedge-trimming': {
    name: 'Hedge Trimming',
    description: 'Keep your hedges and bushes looking neat and well-maintained with our professional trimming services.',
    features: ['Professional shaping', 'Regular maintenance', 'Safety equipment', 'Clean removal of clippings'],
  },
  'leaf-removal': {
    name: 'Leaf Removal',
    description: "Don't let fallen leaves damage your lawn. We offer thorough spring and fall leaf removal services.",
    features: ['Complete leaf cleanup', 'Spring and fall service', 'Bagging and removal', 'Lawn protection'],
  },
  'fertilizing': {
    name: 'Fertilizing',
    description: 'Non-pesticide lawn fertilization for a healthier, greener lawn. Our fertilization program promotes strong root growth and vibrant color.',
    features: ['Multiple applications', 'Non-pesticide formula', 'Root development', 'Enhanced green color'],
  },
  'mulching': {
    name: 'Mulching',
    description: 'Professional mulch installation to beautify your flower beds and retain moisture in your soil.',
    features: ['Fresh mulch installation', 'Weed suppression', 'Moisture retention', 'Curb appeal boost'],
  },
  'overseeding': {
    name: 'Overseeding',
    description: 'Spring and fall overseeding to fill in bare spots and thicken your lawn for a lush appearance.',
    features: ['High-quality seed', 'Bare spot repair', 'Thicker lawn', 'Weed suppression'],
  },
  'snow-removal': {
    name: 'Snow Removal',
    description: 'Reliable snow removal services to keep your driveways and walkways safe and accessible.',
    features: ['Driveway clearing', 'Walkway clearing', 'Timely service', 'Residential properties'],
  },
  'salting': {
    name: 'Salting',
    description: 'Rock salt and calcium chloride application for ice control and safety during winter months.',
    features: ['Ice prevention', 'Driveway treatment', 'Safe walkways', 'Winter safety'],
  },
};

const serviceName: string = service?.name || FALLBACK_INFO[slug as string]?.name || (slug as string).replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
const fallback = FALLBACK_INFO[slug as string] || { description: 'Professional lawn care service.', features: [] as string[] };
const description = service?.shortDescription || fallback.description;
const features = fallback.features;
---

<Layout title={serviceName} description={`${serviceName} services by MI Premier Lawn Care in Flint, MI.`}>
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/services" class="inline-flex items-center gap-2 text-primary-500 hover:text-primary-600 mb-8">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Services
      </a>

      <div class="bg-white rounded-2xl p-8 lg:p-12 shadow-sm">
        <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
          {serviceName}
        </h1>
        
        <p class="text-xl text-gray-600 mb-8">
          {description}
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mb-6">What's Included</h2>
        <ul class="space-y-4 mb-8">
          {features.map((feature) => (
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">{feature}</span>
            </li>
          ))}
        </ul>

        <div class="border-t border-gray-200 pt-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Get Started</h2>
          <p class="text-gray-600 mb-6">
            Ready to get started with {serviceName.toLowerCase()}? Contact us today for a free quote.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={siteData.yardbookUrl || '#'}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-primary-500 hover:bg-primary-600 text-white px-6 py-3 rounded-lg font-semibold transition-colors"
            >
              Get a Free Quote
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href={`tel:${siteData.phoneNumber?.replace(/\D/g, '')}`}
              class="inline-flex items-center justify-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-900 px-6 py-3 rounded-lg font-semibold transition-colors"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {siteData.phoneNumber}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <CTABanner siteData={siteData} />
</Layout>
