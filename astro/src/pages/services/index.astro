---
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/CTABanner.astro';
import { fetchSiteSettings } from '../../lib/sanity';

const siteData = await fetchSiteSettings();
---

<Layout title="Services" description="Professional lawn care services including mowing, hedge trimming, leaf removal, fertilizing, and more in Flint, MI.">
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
          Our Services
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Professional lawn care you can trust. Free estimates on all services.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Lawn Maintenance</h2>
          <ul class="space-y-3 text-gray-600">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong>Mowing:</strong> Weekly and biweekly with string trimming, edging, and blowing</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong>Hedge Trimming:</strong> Professional shaping and maintenance</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong>Mulching:</strong> Fresh mulch installation for flower beds</span>
            </li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Seasonal Services</h2>
          <ul class="space-y-3 text-gray-600">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong>Leaf Removal:</strong> Spring and fall cleanup</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong>Snow Removal:</strong> Driveway and walkway clearing</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong>Salting:</strong> Rock salt and calcium chloride application</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-8 shadow-sm">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Lawn Health Services</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <h3 class="text-lg font-semibold text-gray-900 mb-3">Fertilization</h3>
            <p class="text-gray-600 mb-4">
              Non-pesticide lawn fertilization for a healthier, greener lawn. Our fertilization program 
              includes multiple applications throughout the growing season to keep your lawn lush and vibrant.
            </p>
            <ul class="space-y-2 text-gray-600">
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Spring application
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Summer feeding
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Fall winterization
              </li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900 mb-3">Overseeding</h3>
            <p class="text-gray-600 mb-4">
              Spring and fall overseeding to fill in bare spots and thicken your lawn. 
              We use high-quality seed blends suited for the Michigan climate.
            </p>
            <ul class="space-y-2 text-gray-600">
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Fills thin areas
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Improves lawn density
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Crowd out weeds naturally
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  <CTABanner siteData={siteData} />
</Layout>
