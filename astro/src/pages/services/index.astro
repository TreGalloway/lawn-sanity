---
import Layout from '../../layouts/Layout.astro';
import ServiceTabs from '../../components/ServiceTabs.astro';
import CTABanner from '../../components/CTABanner.astro';
import { fetchSiteSettings, fetchServices } from '../../lib/sanity';
import type { Service } from '../../types';

const siteData = await fetchSiteSettings();
const sanityServices = await fetchServices();

const DEFAULT_SERVICES: Service[] = [
  { _id: '1', name: 'Lawn Mowing', slug: { current: 'lawn-mowing' }, shortDescription: 'Weekly and biweekly mowing with string trimming, edging, and blowing.' },
  { _id: '2', name: 'Hedge Trimming', slug: { current: 'hedge-trimming' }, shortDescription: 'Professional hedge and bush trimming services.' },
  { _id: '3', name: 'Leaf Removal', slug: { current: 'leaf-removal' }, shortDescription: 'Spring and fall leaf removal services.' },
  { _id: '4', name: 'Fertilizing', slug: { current: 'fertilizing' }, shortDescription: 'Non-pesticide lawn fertilization for a healthier, greener lawn.' },
  { _id: '5', name: 'Mulching', slug: { current: 'mulching' }, shortDescription: 'Professional mulch installation services.' },
  { _id: '6', name: 'Overseeding', slug: { current: 'overseeding' }, shortDescription: 'Spring and fall overseeding for a thicker lawn.' },
  { _id: '7', name: 'Snow Removal', slug: { current: 'snow-removal' }, shortDescription: 'Reliable snow removal services for residential properties.' },
  { _id: '8', name: 'Salting', slug: { current: 'salting' }, shortDescription: 'Rock salt and calcium chloride services.' },
];

const services = sanityServices.length > 0 ? sanityServices : DEFAULT_SERVICES;

const FALLBACK_DESCRIPTIONS: Record<string, string> = {
  'lawn-mowing': 'Weekly and biweekly mowing with string trimming, edging, and blowing.',
  'hedge-trimming': 'Professional hedge and bush trimming services.',
  'leaf-removal': 'Spring and fall leaf removal services.',
  'fertilizing': 'Non-pesticide lawn fertilization for a healthier, greener lawn.',
  'mulching': 'Professional mulch installation services.',
  'overseeding': 'Spring and fall overseeding for a thicker lawn.',
  'snow-removal': 'Reliable snow removal services for residential properties.',
  'salting': 'Rock salt and calcium chloride services.',
};
---

<Layout title="Services" description="Professional lawn care services including mowing, hedge trimming, leaf removal, fertilizing, and more in Flint, MI.">
  <ServiceTabs services={services} />
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
          Our Services
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Professional lawn care you can trust. Free estimates on all services.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {services.map((service) => (
          <a
            href={`/services/${service.slug.current}`}
            class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-primary-200"
          >
            <h2 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-500 transition-colors">
              {service.name}
            </h2>
            <p class="text-gray-600 text-sm mb-4">
              {service.shortDescription || FALLBACK_DESCRIPTIONS[service.slug.current] || 'Professional lawn care service.'}
            </p>
            <span class="inline-flex items-center text-primary-500 font-medium text-sm">
              Learn more
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
  <CTABanner siteData={siteData} />
</Layout>
