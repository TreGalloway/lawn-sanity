server {
    listen ${PORT};
    server_name _;
    port_in_redirect off;
    absolute_redirect off;
    root /usr/share/nginx/html;
    index index.html;

    location / {
        try_files $uri $uri/index.html =404;
    }

    location = /health {
        return 200 'OK';
        add_header Content-Type text/plain;
    }
}
